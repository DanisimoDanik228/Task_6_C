<style>
    .visible{
        display:block;
    }

    .invisible {
        display: none;
    }

    #drawingPlace {
        display: grid;
        grid-template-columns: 200px 1fr;
        height: 100vh;
    }

    #canvas-container {
        position: relative;
        width: 100%;
        height: 100%;
    }

    #canvas1, #canvas2 {
        position: absolute;
        left: 0;
        top: 0;
    }

    .btn-green {
        backface-visibility:hidden;
        border-color:green;
        color: green;
    }

    .btn-green:hover {
        background-color: green; 
        color: white;
    }


</style>

<div id="groupPage" class="visible">
    <div class="container-fluid">
        <div class="row min-vh-100">
            <div class="col-12 gradient position-relative">
                <div class="position-absolute rounded-bottom-3 translate-middle-x top-0 start-50 fs-3 fw-light text-uppercase px-3"
                     style="color: var(--maincolor1); background-color: lightgray">
                    Werty Paint Application
                </div>
                <div class="position-absolute top-50 start-50 translate-middle rounded-4 p-2 col-4
text-white border border-4 border-primary border-opacity-10 shadow-lg"
                     style="background-color: var(--maincolor3);">
                    <div id="chooseGroup" class="row">
                        <div class="text-light px-4 col-3">
                            Group Id
                        </div>
                        <div class="col-9">
                            <div class="input-group">
                                <input id="groupIdInput" class="form-control text-light bg-dark" type="number" min="0">
                                <button class="btn btn btn-outline-light px-4" onclick="createGroup(document.getElementById('groupIdInput').value);" style="width:130px;">Create</button>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="text-light px-4 col-3">
                            Name
                        </div>
                        <div class="col-9">
                            <div class="input-group">
                                <input id="currentNameHome" class="form-control text-light bg-dark" type="text">
                                <button id="btnName" class="btn btn-outline-light px-4" onclick="createGroup(document.getElementById('groupIdInput').value);" style="width:130px;">Set Name</button>
                            </div>
                        </div>
                    </div>
                    <div class="p-2 rounded-3 bg-opacity-100 border border-black border-4 border-opacity-25">
                        <div>
                            Name: <span id="currentNameHomeLabel" class="text-info"></span>
                        </div>
                        <div>
                            Status: <span id="currentStatusHome" class="text-info">Senior</span>
                        </div>
                        <div id="userList"></div>
                        <div class="input-group">
                            <select id="statusSelect" class="form-select overflow-auto text-white bg-dark">
                                <option value="Senior">Senior</option>
                                <option value="Middle">Middle</option>
                                <option value="Junior">Junior</option>
                            </select>
                            <button id="btnStatus" class="btn btn-outline-light">Set</button>
                        </div>
                    </div>
                    <div id="groupList"></div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="drawPage" class="invisible">
    <div id="drawingPlace">
        <div>
            <button onclick="setMode('line')">line</button>
            <button onclick="setMode('square')">square</button>
            <button onclick="setMode('pen')">pen</button>
            <button onclick="setMode('circle')">circle</button>
            <button onclick="setMode('text')">text</button>
            <input id="textToDraw" placeholder="text to write" type="text">
            <input type="color" id="colorInput" value=black>
            <div id="showGroupId"></div>
            <div id="currentStatusMain">Status: Senior</div>
            <div>Name: </div>
            <div id="currentNameMain"></div>
            <button onclick="loadHome()">Go home</button>
            <button onclick="saveCanvasAsJpeg();">Download</button>
        </div>
        <div>
            <div id="canvas-container">
                <canvas id="canvas1" width="800" height="800"
                        style="position: absolute; left: 0; top: 0; z-index: 1; border: 1px solid black"></canvas>
                <canvas id="canvas2" width="800" height="800"
                        style="position: absolute; left: 0; top: 0; z-index: 2"></canvas>
            </div>
        </div>
    </div>
</div>
<script type="module">
    import { DrawingApp } from '/js/DrawingApp.js';

    const app = new DrawingApp();
    app.init();

</script>
<script>
    function saveCanvasAsJpeg() {
        const canvas = document.getElementById('canvas1');

        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = canvas.width;
        tempCanvas.height = canvas.height;
        const tempCtx = tempCanvas.getContext('2d');

        tempCtx.fillStyle = "white";
        tempCtx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);

        tempCtx.drawImage(canvas, 0, 0);

        const dataUrl = tempCanvas.toDataURL('image/jpeg', 0.9);

        const link = document.createElement('a');
        link.download = 'my-drawing.jpg';
        link.href = dataUrl;
        link.click();
    }
</script>